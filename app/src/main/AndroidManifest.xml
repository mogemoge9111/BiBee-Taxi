<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <application
        android:name=".MapApplication"
        android:allowBackup="true"
        android:enableOnBackInvokedCallback="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/iconica"
        android:label="@string/app_name"
        android:roundIcon="@drawable/iconica"
        android:supportsRtl="true"
        android:theme="@style/Theme.BiBeeTaxi"
        tools:targetApi="31">
        <activity
            android:name=".CreateRideRequestActivity"
            android:exported="false" />
        <!-- Заставка -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity> <!-- Выбор роли -->
        <activity
            android:name=".WelcomeActivity"
            android:exported="false" /> <!-- Вход / Регистрация -->
        <activity
            android:name=".LoginActivity"
            android:exported="false" /> <!-- Основной экран пассажира (с фрагментами) -->
        <activity
            android:name=".MainPassengerActivity"
            android:exported="false" /> <!-- Основной экран водителя (с фрагментами) -->
        <activity
            android:name=".MainDriverActivity"
            android:exported="false" /> <!-- Старые активности с картой – можно удалить позже, пока оставим для совместимости -->
        <activity
            android:name=".PassengerMapActivity"
            android:exported="false" />
        <activity
            android:name=".DriverMapActivity"
            android:exported="false" />
        <activity
            android:name=".ChatActivity"
            android:exported="false" />
        <activity
            android:name=".DriverProfileViewActivity"
            android:exported="false" />
        <activity
            android:name=".DriverSetupActivity"
            android:exported="false" />

        <activity android:name=".RideConfirmationActivity" android:exported="false" />
        <activity android:name=".EditRideRequestActivity" android:exported="false" />
        <activity android:name=".SupportActivity" android:exported="false" />
    </application>

</manifest>